# ──────────────────────────────────────────────────────────────
# MintMoment — Environment configuration
# Copy this file to `.env` and fill in your real values.
# ──────────────────────────────────────────────────────────────

# Server
PORT=10000
NODE_ENV=production

# X Layer (OKX) mainnet — chain ID 196, CAIP-2 eip155:196
X_LAYER_RPC=https://rpc.xlayer.tech
X_LAYER_CHAIN_ID=196
X_LAYER_EXPLORER=https://www.oklink.com/xlayer

# Wallet that RECEIVES payments for paid services
# This is the onchain identity linked to the MintMoment ASP listing
RECEIVE_ADDRESS=0x8bfc0f414be2f70c5930f7713be1db188eb0c3bd

# Asset used for settlement (USDT0 on X Layer, 6 decimals)
PAYMENT_ASSET=USDT0
PAYMENT_ASSET_ADDRESS=0x779ded0c9e1022225f8a06d3a3c4b3f1e6d5b4d3
PAYMENT_ASSET_DECIMALS=6

# Agent identity (used in x402 manifest + X post)
AGENT_NAME=MintMoment
AGENT_TAGLINE=Your life, minted onchain.
AGENT_EMAIL=fijinfolu@gmail.com
AGENT_CATEGORY=Lifestyle
AGENT_DESCRIPTION=A Lifestyle Companion ASP that turns personal moments into onchain keepsakes on X Layer. Free previews, paid mints, gift to a friend, or build a whole year of memories — every keepsake settles in USDT0 via x402 v2 and is permanently viewable on the OKLink X Layer explorer.

# Public URL (set after first Render deploy)
PUBLIC_URL=https://mintmoment.onrender.com

# Optional: pin a default image provider for the keepsake generator
# If unset, keepsakes use a deterministic text-art fallback so the
# service works out-of-the-box with no external API keys.
IMAGE_PROVIDER=fallback
